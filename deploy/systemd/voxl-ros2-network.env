ROS_DOMAIN_ID=0
RMW_IMPLEMENTATION=rmw_fastrtps_cpp
ROS_DISCOVERY_SERVER=127.0.0.1:11811
ROS_SUPER_CLIENT=TRUE
ROS_LOCALHOST_ONLY=0

# Optional: absolute path to the voxl_mpa_to_ros2 node executable.
# If this path is valid and executable, the systemd service will launch it
# directly; otherwise it falls back to `ros2 run voxl_mpa_to_ros2 ...`.
# VOXL_MPA_NODE_BIN=/opt/ros/foxy/mpa_to_ros2/install/voxl_mpa_to_ros2/lib/voxl_mpa_to_ros2/voxl_mpa_to_ros2
